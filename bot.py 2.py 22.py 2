import discord
import os
import random
import requests
from discord.ext import commands
from passgen2 import gen_pass
intents = discord.Intents.default()
intents.message_content = True
bot = commands.Bot(command_prefix='$', intents=intents)
@bot.event
async def on_ready():
    print(f'We have logged in as {bot.user}')
@bot.command()
async def hello(ctx):
    await ctx.send(f'Hi! I am a bot {bot.user}!')
@bot.command()
async def gacha(ctx):
    Sanrio = ['Hello Kitty', 'Kuromi', 'My Melody', 'Cinnamoroll']
    await ctx.send(random.choice(Sanrio))

@bot.command()
async def genpass(ctx, length = 5) :
    await ctx.send(genpass(length))


